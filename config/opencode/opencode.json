{
  "$schema": "https://opencode.ai/config.json",
  "model": "llamacpp/default_model",
  "small_model": "llamacpp/default_model",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LlamaCpp (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "Qwen 3.6 35B A3B"
        }
      }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "Qwen 3.6 35B A3B"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-5e927b12-be34-4151-a06b-191d24a4b388"
      },
      "enabled": true
    },
    "MCP_DOCKER": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    }
  }
}
